{
  "name": "soft-feedback-monorepo",
  "private": true,
  "version": "0.0.0",
  "description": "Soft, delightful, white-label feedback & micro-survey widgets your users actually want to answer.",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "dev": "npm run dev --workspace=soft-feedback --if-present"
  },
  "devDependencies": {
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=18"
  }
}
