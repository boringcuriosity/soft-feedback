{
  "name": "soft-feedback",
  "version": "0.1.0",
  "description": "Soft, delightful, white-label feedback & micro-survey widgets your users actually want to answer. Headless, framework-agnostic, accessible. CSAT, NPS, CES.",
  "homepage": "https://github.com/boringcuriosity/soft-feedback#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/boringcuriosity/soft-feedback.git",
    "directory": "packages/core"
  },
  "bugs": "https://github.com/boringcuriosity/soft-feedback/issues",
  "keywords": [
    "feedback",
    "feedback-widget",
    "survey",
    "microsurvey",
    "nps",
    "csat",
    "ces",
    "rating",
    "emoji",
    "widget",
    "headless",
    "web-component",
    "accessible"
  ],
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "unpkg": "./dist/index.global.js",
  "jsdelivr": "./dist/index.global.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepack": "cp ../../README.md ../../LICENSE .",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.6.0"
  }
}
