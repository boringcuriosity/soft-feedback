{
  "name": "soft-feedback",
  "version": "0.0.0",
  "description": "Soft, delightful, white-label feedback & micro-survey widgets your users actually want to answer. Headless, framework-agnostic, accessible. CSAT, NPS, CES.",
  "keywords": [
    "feedback",
    "feedback-widget",
    "survey",
    "microsurvey",
    "nps",
    "csat",
    "ces",
    "rating",
    "emoji",
    "widget",
    "headless",
    "web-component",
    "accessible"
  ],
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "unpkg": "./dist/index.global.js",
  "jsdelivr": "./dist/index.global.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.6.0"
  }
}
